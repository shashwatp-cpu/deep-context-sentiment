# API Keys
APIFY_API_TOKEN=your_apify_token

# Google Cloud / Vertex AI
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=asia-south1

# Processing Settings
BATCH_SIZE=10
MAX_COMMENTS=100
MAX_CONCURRENT_BATCHES=5
REQUEST_TIMEOUT=300

# Platform Limits
# YOUTUBE_COMMENT_LIMIT=100
# FACEBOOK_COMMENT_LIMIT=100
# TWITTER_COMMENT_LIMIT=100
# INSTAGRAM_COMMENT_LIMIT=100

# App Configuration
APP_NAME=Sentiment Analysis API
VERSION=1.0.0

# Frontend Settings (for docker-compose)
# REACT_APP_API_URL=http://localhost:8000